---
// Портировано из index.html:1073–1106 ("FLOATING CHAT"). В легаси это два
// взаимоисключающих x-dc-блока: `<sc-if value="{{ chatOpen }}">` (1074–1100,
// сама панель чата) и `<sc-if value="{{ chatClosed }}">` (1101–1106,
// плавающая кнопка) — переключались по state.chatOpen (изначально false,
// index.html:1141 → кнопка видна, панель скрыта).
//
// Сообщения (`<sc-for list="{{ chatMsgs }}" as="m">`, index.html:1084–1086)
// рендерились из state.chat — массива с одним стартовым сообщением бота
// (index.html:1144): текст зависел от navigator.language (RU/EN ternary).
// Здесь вместо navigator.language решает проп locale страницы (см. Astro-обход
// правила: "NOT navigator.language; page locale prop decides") — greeting
// берётся из dict.chat.greeting текущей локали и рендерится статически как
// единственное стартовое сообщение в data-chat-messages.
//
// ВЕРИФИЦИРОВАНО КАК ЖИВОЙ JS — контракт для Task 18, логика НЕ переносится
// сюда, только разметка и data-* хуки:
//   openChat/closeChat (index.html:1692–1693) — setState({chatOpen:true/false})
//   onChatInput (1694) — setState({chatInput: e.target.value})
//   sendChat (1695) → doSend() (1708–1728):
//     - если state.chatInput пуст или chatBusy — no-op
//     - добавляет user-сообщение в историю, чистит input, chatBusy=true
//     - пробует window.claude.complete({system: SYSTEM_PROMPT, max_tokens:400,
//       messages: history.map(...)}) (1716–1723) — НЕ HTTP fetch, а
//       клиентский API претрейнед-модели, если доступен в окружении
//     - при отсутствии/ошибке — this.pickReply(text) как фолбэк (1726, сама
//       функция — index.html:1741+, локальный подбор ответа по ключевым словам)
//     - результат добавляется как bot-сообщение, chatBusy=false
//   componentDidUpdate (1699–1702) — автоскролл контейнера сообщений к низу
//     при любом обновлении (ref chatScroll, index.html:1083)
//   Индикатор "печатает" — `<sc-if value="{{ chatBusy }}">` (1087–1093),
//     3 точки с анимацией rk-type (уже в global.css, портирована 1:1)
//   NB: `chatWrap` (index.html:1614, `(el)=>(this.el.chatWrap=el)`) присваивался,
//     но НИ РАЗУ не использовался как `ref` ни в одном узле разметки 1073–1106 —
//     мёртвый код, аналогично rk-store-grid/rk-arrow в Storefront.astro;
//     не портируется.
//
// data-* хуки для Task 18:
//   [data-chat-open]      — плавающая кнопка "Спросить ассистента" (видна изначально)
//   [data-chat-panel]     — панель чата (изначально hidden — chatOpen=false)
//   [data-chat-close]     — кнопка закрытия панели (крестик)
//   [data-chat-messages]  — контейнер сообщений; уже содержит стартовое
//                           bot-сообщение (dict.chat.greeting), дальнейшие
//                           сообщения добавляются сюда JS'ом (см. is:global
//                           ниже — стили .rk-chat-msg должны матчиться и на
//                           узлы, вставленные вне Astro-компиляции)
//   [data-chat-typing]    — индикатор "печатает" (изначально hidden — chatBusy=false)
//   [data-chat-form]      — <form> ввода сообщения (submit — эквивалент sendChat)
//   [data-chat-input]     — текстовое поле ввода
//   [data-chat-send]      — кнопка отправки (submit)
//   Модификаторы сообщений: класс `.rk-chat-msg` + `.is-user`/`.is-bot`
//   (1:1 из m.align/m.bg/m.fg/m.border/m.radius, index.html:1681–1688) — JS
//   Task 18 при добавлении сообщения должен ставить один из этих модификаторов.
//
// CSS-решение: контейнер панели/кнопки и статически известная разметка —
// обычный scoped <style>. НО стили самих пузырей сообщений (.rk-chat-msg и
// модификаторы) и индикатора "печатает" (.rk-chat-typing) вынесены в отдельный
// `<style is:global>`, т.к. Task 18 будет дорисовывать новые пузыри сообщений
// через JS (innerHTML/appendChild) — эти узлы не получат data-astro-cid этого
// файла, и обычный scoped-селектор их не заматчит (та же причина, что и в
// Storefront.astro для .rk-scene*, см. комментарий в шапке того файла).
import { t } from '../i18n/ui';
import type { Locale } from '../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale).chat;
---

<button type="button" class="rk-chat-fab" data-chat-open data-lens="target">
  <svg viewBox="0 0 100 100" width="24" height="24" aria-hidden="true"><rect x="20" y="20" width="26" height="8" rx="2" fill="#F9F5EC"/><rect x="20" y="20" width="8" height="26" rx="2" fill="#F9F5EC"/><g transform="rotate(12 68 26)"><rect x="54" y="20" width="26" height="8" rx="2" fill="#E37722"/><rect x="72" y="20" width="8" height="26" rx="2" fill="#E37722"/></g><rect x="20" y="72" width="26" height="8" rx="2" fill="#F9F5EC"/><rect x="20" y="54" width="8" height="26" rx="2" fill="#F9F5EC"/><rect x="54" y="72" width="26" height="8" rx="2" fill="#F9F5EC"/><rect x="72" y="54" width="8" height="26" rx="2" fill="#F9F5EC"/></svg>
  {dict.openCta}
</button>

<div class="rk-chat-panel" data-chat-panel hidden>
  <div class="rk-chat-header">
    <div class="rk-chat-header-id">
      <svg viewBox="0 0 100 100" width="24" height="24" aria-hidden="true"><rect x="20" y="20" width="26" height="8" rx="2" fill="#241F1B"/><rect x="20" y="20" width="8" height="26" rx="2" fill="#241F1B"/><g transform="rotate(12 68 26)"><rect x="54" y="20" width="26" height="8" rx="2" fill="#E37722"/><rect x="72" y="20" width="8" height="26" rx="2" fill="#E37722"/></g><rect x="20" y="72" width="26" height="8" rx="2" fill="#241F1B"/><rect x="20" y="54" width="8" height="26" rx="2" fill="#241F1B"/><rect x="54" y="72" width="26" height="8" rx="2" fill="#241F1B"/><rect x="72" y="54" width="8" height="26" rx="2" fill="#241F1B"/></svg>
      <div>
        <div class="rk-chat-title">{dict.title}</div>
        <div class="rk-chat-status">{dict.status}</div>
      </div>
    </div>
    <button type="button" data-chat-close aria-label="Close" class="rk-chat-closebtn">&times;</button>
  </div>

  <div class="rk-chat-messages" data-chat-messages>
    <div class="rk-chat-msg is-bot">{dict.greeting}</div>
    <div class="rk-chat-typing" data-chat-typing hidden>
      <span></span><span></span><span></span>
    </div>
  </div>

  <form class="rk-chat-form" data-chat-form>
    <input type="text" data-chat-input placeholder={dict.inputPlaceholder} class="rk-chat-inputfield" />
    <button type="submit" data-chat-send data-lens="target" class="rk-chat-sendbtn">&rarr;</button>
  </form>
</div>

<style>
  .rk-chat-fab {
    position: fixed;
    right: clamp(14px, 3vw, 28px);
    bottom: clamp(14px, 3vw, 28px);
    z-index: 9000;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #241f1b;
    color: #f9f5ec;
    border: none;
    cursor: pointer;
    padding: 13px 18px 13px 15px;
    border-radius: 30px;
    box-shadow: 0 14px 34px rgba(36, 31, 27, 0.32);
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 14px;
    animation: rk-float 4s ease-in-out infinite;
  }

  /* Специфичность .rk-chat-panel{display:flex} (ниже) выше, чем у UA-правила
     [hidden]{display:none} — без явного [hidden]-оверрайда панель осталась бы
     видимой, даже получив атрибут hidden (Task 18 переключает его же). */
  .rk-chat-panel[hidden] {
    display: none;
  }
  .rk-chat-panel {
    position: fixed;
    right: clamp(14px, 3vw, 28px);
    bottom: clamp(14px, 3vw, 28px);
    z-index: 9000;
    width: min(360px, calc(100vw - 28px));
    background: #f5f0e6;
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 24px 60px rgba(36, 31, 27, 0.28);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .rk-chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }
  .rk-chat-header-id {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rk-chat-title {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 14px;
    color: #241f1b;
  }
  .rk-chat-status {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #7e8c7c;
  }
  .rk-chat-closebtn {
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 20px;
    color: #6e6259;
    line-height: 1;
    padding: 4px;
  }

  .rk-chat-form {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid var(--border);
    background: #fff;
  }
  .rk-chat-inputfield {
    flex: 1;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 11px 13px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: #f5f0e6;
    color: #241f1b;
    min-width: 0;
  }
  .rk-chat-sendbtn {
    border: none;
    background: var(--accent);
    color: #f9f5ec;
    border-radius: 10px;
    padding: 0 16px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
  }
</style>

<style is:global>
  /* Пузыри сообщений и индикатор "печатает" — global, см. комментарий в шапке
     файла: Task 18 добавляет новые .rk-chat-msg узлы через JS вне компиляции
     Astro, обычный scoped-стиль их бы не заматчил. */
  .rk-chat-messages {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 340px;
    min-height: 200px;
    overflow-y: auto;
  }
  .rk-chat-msg {
    padding: 9px 13px;
    font-size: 13.5px;
    line-height: 1.5;
    max-width: 84%;
    border: 1px solid;
  }
  .rk-chat-msg.is-bot {
    align-self: flex-start;
    background: #ffffff;
    color: #241f1b;
    border-color: #e4dbcd;
    border-radius: 13px 13px 13px 3px;
  }
  .rk-chat-msg.is-user {
    align-self: flex-end;
    background: #241f1b;
    color: #f9f5ec;
    border-color: #241f1b;
    border-radius: 13px 13px 3px 13px;
  }
  /* см. комментарий у .rk-chat-panel[hidden] — тот же конфликт специфичности
     с display:flex ниже. */
  .rk-chat-typing[hidden] {
    display: none;
  }
  .rk-chat-typing {
    align-self: flex-start;
    background: #ffffff;
    border: 1px solid #e4dbcd;
    border-radius: 13px 13px 13px 3px;
    padding: 10px 13px;
    display: flex;
    gap: 4px;
  }
  .rk-chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6e6259;
    animation: rk-type 1.1s infinite;
  }
  .rk-chat-typing span:nth-child(2) {
    animation-delay: 0.2s;
  }
  .rk-chat-typing span:nth-child(3) {
    animation-delay: 0.4s;
  }
</style>

<script>
  import { initChat } from '../scripts/chat';
  initChat();
</script>
