        {dict.headlineBefore}<span class="rk-hero-hl"><span class="rk-hero-hl-text">{dict.headlineHighlight}</span><span class="rk-hero-hl-mark"></span></span>{dict.headlineAfter}
      </h1>
      <p data-reveal class="rk-hero-sub">{dict.subline}</p>
      <div data-reveal class="rk-hero-ctas">
        <a href="#storefront" data-lens="target" data-magnet class="rk-hero-cta-primary">{dict.ctaPrimary}</a>
        <a href="#storefront" data-lens="target" class="rk-hero-cta-secondary">{dict.ctaSecondary}</a>
