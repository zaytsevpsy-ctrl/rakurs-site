---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Pain from '../components/Pain.astro';
import Storefront from '../components/Storefront.astro';
import How from '../components/How.astro';
import Flagship from '../components/Flagship.astro';
import Founders from '../components/Founders.astro';
import Cases from '../components/Cases.astro';
import Faq from '../components/Faq.astro';
import LeadForm from '../components/LeadForm.astro';
import ChatWidget from '../components/ChatWidget.astro';
import Footer from '../components/Footer.astro';
import { organization, website, professionalService, faqPage } from '../lib/jsonld';
import { getLocalized } from '../lib/content';

const locale = 'ru';
const site = Astro.site!.href;
const products = await getLocalized('products', locale);
const cases = await getLocalized('cases', locale);
const faqItems = await getLocalized('faq', locale);
const ld = [
  organization(site),
  website(site),
  professionalService(
    site,
    products.map((p) => ({
      jsonldName: p.data.jsonldName,
      jsonldDesc: p.data.jsonldDesc,
      priceFrom: p.data.priceFrom,
    })),
  ),
  faqPage(
    faqItems.map((f) => ({
      question: f.data.question,
      answer: f.data.answer,
    })),
  ),
];
---
<Base
  title="Rakurs — ИИ-автоматизация бизнеса: готовые ИИ-решения и диагностика операционных потерь | AI Automation Agency"
  description="Rakurs находит, где бизнес теряет деньги, и закрывает это готовыми ИИ-решениями: ИИ-ассистент для продаж 24/7, автоматизация обработки заявок, ИИ-база знаний, генератор КП. Фиксированная цена, запуск за 1–3 недели. AI automation for business: fixed price, launch in 1–3 weeks."
  path=""
  locale={locale}
>
  <Fragment slot="head">
    {ld.map((obj) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </Fragment>
  <Nav locale={locale} path="" />
  <main>
    <Hero locale={locale} />
    <Pain locale={locale} />
    <Storefront products={products} locale={locale} />
    <How locale={locale} />
    <Flagship locale={locale} />
    <Cases cases={cases} locale={locale} />
    <Founders locale={locale} />
    <Faq faqItems={faqItems} locale={locale} />
    <LeadForm locale={locale} />
  </main>
  <Footer locale={locale} />
  <ChatWidget locale={locale} />
</Base>
