---
import Seo from '../components/Seo.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;
  locale: 'ru' | 'en';
  ogImage?: string;
}
const { title, description, path, locale, ogImage } = Astro.props;
const goatcounter = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo {title} {description} {path} {locale} ogImage={ogImage} />
    <meta name="author" content="Rakurs — Andrey Zaytsev, Egor" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23E37722'/%3E%3Ctext x='32' y='47' font-family='ui-monospace,SFMono-Regular,Menlo,Consolas,monospace' font-size='42' font-weight='700' text-anchor='middle' fill='%23F9F5EC'%3Er%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    {goatcounter && (
      <script is:inline data-goatcounter={`https://${goatcounter}.goatcounter.com/count`} async src="https://gc.zgo.at/count.js"></script>
    )}
    <slot name="head" />
  </head>
  <body>
    <!-- Курсор-линза: в легаси (index.html:310–319) это статическая разметка внутри
         рутового div, а не элемент, создаваемый JS-ом. setupLens() в
         src/scripts/reveal.ts ищет её через [data-cursor-lens]/[data-cursor-lens-dot]. -->
    <div
      data-cursor-lens
      style="position: fixed; left: 0; top: 0; width: 46px; height: 46px; z-index: 9998; pointer-events: none; opacity: 0; transform: translate(-100px,-100px); transition: opacity .25s, width .18s ease, height .18s ease;"
    >
      <svg viewBox="0 0 46 46" width="100%" height="100%" style="overflow: visible;">
        <path d="M4 14 L4 4 L14 4" fill="none" stroke="#241F1B" stroke-width="3" stroke-linecap="round" />
        <path d="M32 4 L42 4 L42 14" fill="none" stroke="#E37722" stroke-width="3" stroke-linecap="round" transform="rotate(12 37 9)" />
        <path d="M4 32 L4 42 L14 42" fill="none" stroke="#241F1B" stroke-width="3" stroke-linecap="round" />
        <path d="M42 32 L42 42 L32 42" fill="none" stroke="#241F1B" stroke-width="3" stroke-linecap="round" />
        <circle data-cursor-lens-dot cx="23" cy="23" r="1.6" fill="#E37722" opacity="0" />
      </svg>
    </div>
    <slot />
    <script>
      import { initReveal } from '../scripts/reveal';
      initReveal();
    </script>
  </body>
</html>
