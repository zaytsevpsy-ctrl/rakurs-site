---
// Портировано из index.html:504–633 (section#pain, тёмная секция: заголовок,
// live-виджет "отчёт" SURFACE/TRUE-слоёв и три карточки "дыра_0N" (.rk-holes)).
//
// setupReport() (index.html:1391–1457, вызывается из componentDidMount()) реально
// ищет [data-report] / [data-report-true] / [data-report-ring] / [data-report-status]
// — ВСЕ четыре присутствуют в разметке ниже и являются НЕ мёртвым кодом (в отличие
// от setupPipe() в Hero.astro, см. его комментарий). Сохранены как live JS-хуки —
// 1:1 имена, ничего не выдумано. Контракт для Task 16 (оживление интерактива):
//   [data-report]        — контейнер-карточка; JS слушает mousemove/mouseleave
//                           (desktop) и pointerdown/move (touch, drag хвата)
//   [data-report-true]   — тёмный "истинный" слой; JS двигает круг-маску
//                           (mask-image: radial-gradient) за курсором и меняет
//                           .style.opacity/.maskImage инлайново — базовое
//                           "выключенное" состояние (opacity:0, radius 0) задано
//                           ниже в scoped-стиле и переопределяется JS в рантайме
//   [data-report-ring]   — кольцо-лупа за курсором (desktop only)
//   [data-report-status] — статус в правом верхнем углу SURFACE; JS подставляет
//                           туда ЖЁСТКО ЗАШИТЫЕ EN-строки ('● the real picture' /
//                           '● goals met') напрямую в support.js, а не из словаря;
//                           начальный статичный текст = dict.pain.reportStatusGood
//                           — совпадает с тем, что JS ставит на mouseleave.
//
// dict.pain.reportStatusGood хранит буквально '● goals met' — так в источнике:
// это единственная строка внутри #pain, которую легаси i18n-переводчик (setupLang,
// index.html:1163–1290) никогда не тронет ни в RU, ни в EN — он ищет кириллицу для
// перевода, а эта строка уже на английском в RU-разметке. Поэтому она одинакова
// в src/i18n/ru.ts и src/i18n/en.ts (не "забытый перевод" — 1:1 порт факта).
//
// Правила из <style id="rk-fixes"> (index.html:45–192), перенесённые сюда:
//  - строки 47–50 (@media 620px): `[data-report]{max-width:100%!important}` +
//    `[data-report]>div{padding-left/right:12px!important}` — перенесены как есть,
//    атрибут data-report сохранён на разметке, селектор продолжает матчиться
//    (три прямых div-потомка: SURFACE / TRUE / ring — совпадает 1:1).
//  - строки 84–85 (без media, действует всегда): легаси-селектор
//    `[data-report] div[style*="padding: 11px 12px"] > div:first-child` /
//    `:last-child` бил по подстроке инлайн-style. После перевода инлайн-стилей
//    в классы такой селектор перестал бы матчиться — заменён классом
//    `.rk-report-kpi` с тем же визуальным эффектом (однострочные лейблы/значения).
//  - строки 186–190 (@media 768px): `.rk-holes{display:flex!important;
//    overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;
//    gap:12px!important;margin:0 -20px;padding:0 20px 10px;scrollbar-width:none}`
//    + `::-webkit-scrollbar{display:none}` + `>div{flex:0 0 80%;scroll-snap-align:
//    center;min-width:0}`. Это НЕ конфликтует с уже портированным в global.css
//    (index.html:258–306) правилом `.rk-holes{grid-template-columns:1fr!important}`
//    для того же брейкпоинта — оба правила бьют в разные CSS-свойства и спокойно
//    сосуществуют (grid-template-columns не имеет эффекта на flex-контейнере).
//    Здесь допорчено недостающее (flex/scroll-snap/scrollbar-hide).
//
// Калькулятор потерь (loss/share slider, "СКОЛЬКО КОМПАНИЯ ТЕРЯЕТ...") живёт в
// #flagship (index.html:772–803, см. Flagship.astro) — НЕ в этой секции, не путать
// с виджетом "отчёт" выше.
import { t } from '../i18n/ui';
import type { Locale } from '../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale).pain;

// KPI-мини-карточки: 6 в SURFACE-слое (index.html:519–544, все "хорошие"/зелёные),
// 6 в TRUE-слое (index.html:565–590, все "плохие"/красные). Значения и стрелки —
// не переводимые данные мокапа (числа/валюта), см. dict.* только для лейблов.
const kpiSurface = [
  { label: dict.kpiRevenue, value: '+18%' },
  { label: dict.kpiProfit, value: '+12%' },
  { label: dict.kpiSla, value: '98%' },
  { label: dict.kpiConversion, value: '+7%' },
  { label: dict.kpiNps, value: '71' },
  { label: dict.kpiLoad, value: '94%' },
];
const kpiTrue = [
  { label: dict.kpiLost, value: '−$38K', arrow: '▼' },
  { label: dict.kpiPayrollIdle, value: '31%', arrow: '▲' },
  { label: dict.kpiSlaNight, value: '61%', arrow: '▼' },
  { label: dict.kpiChurn, value: '+9%', arrow: '▲' },
  { label: dict.kpiCritErrors, value: '47', arrow: '▲' },
  { label: dict.kpiRoutine, value: '38%', arrow: '▲' },
];
// высоты столбиков графика (index.html:545–552 / 591–598) — тоже данные мокапа
const barsGood = [40, 50, 58, 70, 82, 95];
const barsBad = [95, 80, 66, 52, 40, 28];

const holes = [
  { title: dict.hole1Title, desc: dict.hole1Desc, tag: dict.hole1Tag },
  { title: dict.hole2Title, desc: dict.hole2Desc, tag: dict.hole2Tag },
  { title: dict.hole3Title, desc: dict.hole3Desc, tag: dict.hole3Tag },
];
---

<section id="pain">
  <div class="rk-pain-inner">
    <div data-reveal class="rk-pain-eyebrow">{dict.eyebrow}</div>
    <h2 data-reveal class="rk-pain-heading">{dict.heading}</h2>
    <p data-reveal class="rk-pain-lead">{dict.lead}</p>

    <div data-reveal class="rk-pain-report-wrap">
      <div data-report class="rk-report">
        <!-- SURFACE (looks great) -->
        <div class="rk-report-surface">
          <div class="rk-report-toprow">
            <span class="rk-report-title">DASHBOARD · Q2 2026</span>
            <span data-report-status class="rk-report-status rk-report-status-good">{dict.reportStatusGood}</span>
          </div>
          <div class="rk-report-kpigrid">
            {kpiSurface.map((k) => (
              <div class="rk-report-kpi rk-report-kpi-good">
                <div>{k.label}</div>
                <div class="rk-report-kpi-row"><span class="rk-report-kpi-value">{k.value}</span><span class="rk-report-arrow-good">▲</span></div>
              </div>
            ))}
          </div>
          <div class="rk-report-chart rk-report-chart-good">
            {barsGood.map((h) => (
              <div class="rk-report-bar rk-report-bar-good" style={`height:${h}%`}></div>
            ))}
          </div>
          <div class="rk-report-bottomrow">
            <span class="rk-report-caption-good">{dict.chartCaptionGood}</span>
            <span class="rk-report-caption-muted">{dict.chartQGood}</span>
          </div>
        </div>

        <!-- TRUE layer (revealed under the lens spotlight) -->
        <div data-report-true class="rk-report-true">
          <div class="rk-report-toprow-flat">
            <span class="rk-report-title-bad">{dict.reportTrueTitle}</span>
            <span class="rk-report-status-bad">{dict.reportStatusBad}</span>
          </div>
          <div class="rk-report-kpigrid">
            {kpiTrue.map((k) => (
              <div class="rk-report-kpi rk-report-kpi-bad">
                <div>{k.label}</div>
                <div class="rk-report-kpi-row"><span class="rk-report-kpi-value-bad">{k.value}</span><span class="rk-report-arrow-bad">{k.arrow}</span></div>
              </div>
            ))}
          </div>
          <div class="rk-report-chart rk-report-chart-bad">
            {barsBad.map((h) => (
              <div class="rk-report-bar rk-report-bar-bad" style={`height:${h}%`}></div>
            ))}
          </div>
          <div class="rk-report-bottomrow">
            <span class="rk-report-caption-bad">{dict.chartCaptionBad}</span>
            <span class="rk-report-caption-mutedbad">{dict.chartQBad}</span>
          </div>
        </div>

        <!-- lens ring following cursor -->
        <div data-report-ring class="rk-report-ring"></div>
      </div>
      <div class="rk-pain-hint">{dict.reportHint}</div>
    </div>

    <div class="rk-holes">
      {holes.map((h) => (
        <div data-reveal class="rk-hole-card">
          <div class="rk-hole-title">{h.title}</div>
          <p class="rk-hole-desc">{h.desc}</p>
          <div class="rk-hole-tag">{h.tag}</div>
        </div>
      ))}
    </div>

    <p data-reveal class="rk-pain-closing">{dict.closingBefore}<span class="rk-pain-closing-hl">{dict.closingHighlight}</span>{dict.closingAfter}</p>
  </div>
</section>

<style>
  #pain {
    background: var(--bg-dark);
    color: var(--ink-on-dark);
    padding: clamp(52px, 7vh, 80px) clamp(20px, 5vw, 64px);
  }
  .rk-pain-inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .rk-pain-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--ink-muted-dark);
    margin-bottom: 20px;
  }
  .rk-pain-heading {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: clamp(28px, 3.4vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    max-width: 900px;
  }
  .rk-pain-lead {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.6;
    color: #cfc5b8;
    max-width: 720px;
    margin: 0 0 12px;
  }

  .rk-pain-report-wrap {
    margin: 28px 0 30px;
  }
  .rk-report {
    position: relative;
    border: 1px solid #35302b;
    border-radius: 16px;
    overflow: hidden;
    background: #211d19;
    cursor: none;
  }
  .rk-report-surface {
    padding: 16px 20px;
  }
  .rk-report-toprow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 15px;
    position: relative;
  }
  .rk-report-toprow-flat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 15px;
  }
  .rk-report-title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-muted-dark);
  }
  .rk-report-title-bad {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #f0653f;
  }
  .rk-report-status {
    font-family: var(--font-mono);
    font-size: 11px;
    transition: color 0.3s;
    white-space: nowrap;
  }
  .rk-report-status-good {
    color: #7fb77e;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
  }
  .rk-report-status-bad {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #f0653f;
  }

  .rk-report-kpigrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 14px;
  }
  .rk-report-kpi {
    border-radius: 10px;
    padding: 11px 12px;
  }
  .rk-report-kpi-good {
    background: #14180f;
    border: 1px solid #26402a;
  }
  .rk-report-kpi-good > div:first-child {
    font-family: var(--font-mono);
    color: #7f9a7c;
    margin-bottom: 7px;
  }
  .rk-report-kpi-bad {
    background: #26100a;
    border: 1px solid #5a2a18;
  }
  .rk-report-kpi-bad > div:first-child {
    font-family: var(--font-mono);
    color: #c58a5a;
    margin-bottom: 7px;
  }
  /* rk-fixes (index.html:84–85), без media, действует всегда: однострочные
     лейблы/значения KPI-карточек в обоих слоях. Легаси-селектор бил по подстроке
     инлайн-style ("div[style*='padding: 11px 12px']") — здесь заменён классом. */
  .rk-report-kpi > div:first-child {
    font-size: 8.5px !important;
    letter-spacing: 0 !important;
    white-space: nowrap !important;
  }
  .rk-report-kpi > div:last-child {
    white-space: nowrap !important;
  }
  .rk-report-kpi-row {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }
  .rk-report-kpi-value {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 21px;
    color: #8fd08a;
  }
  .rk-report-kpi-value-bad {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 21px;
    color: #f0653f;
  }
  .rk-report-arrow-good {
    color: #6fb56a;
    font-size: 12px;
  }
  .rk-report-arrow-bad {
    color: #f0653f;
    font-size: 12px;
  }

  .rk-report-chart {
    display: flex;
    align-items: flex-end;
    gap: 7px;
    height: 66px;
    padding: 0 2px;
    border-bottom: 1px solid;
  }
  .rk-report-chart-good {
    border-bottom-color: #26402a;
  }
  .rk-report-chart-bad {
    border-bottom-color: #5a2a18;
  }
  .rk-report-bar {
    flex: 1;
    border-radius: 3px 3px 0 0;
  }
  .rk-report-bar-good {
    background: linear-gradient(#8fd08a, #4f7a4c);
  }
  .rk-report-bar-bad {
    background: linear-gradient(#f0653f, #8f2f16);
  }

  .rk-report-bottomrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 10px;
  }
  .rk-report-caption-good {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: #7fb77e;
  }
  .rk-report-caption-muted {
    font-family: var(--font-mono);
    font-size: 9px;
    color: #6e6259;
  }
  .rk-report-caption-bad {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: #f0653f;
  }
  .rk-report-caption-mutedbad {
    font-family: var(--font-mono);
    font-size: 9px;
    color: #c58a5a;
  }

  .rk-report-true {
    position: absolute;
    inset: 0;
    background: #130b07;
    padding: 16px 20px;
    /* начальное "выключенное" состояние — JS (setupReport) переопределяет
       .style.opacity/.maskImage инлайново при mousemove/touch-драге */
    opacity: 0;
    -webkit-mask-image: radial-gradient(circle 0px at 50% 50%, #000 60%, transparent 72%);
    mask-image: radial-gradient(circle 0px at 50% 50%, #000 60%, transparent 72%);
  }

  .rk-report-ring {
    position: absolute;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 1.5px solid rgba(237, 160, 92, 0.6);
    box-shadow: 0 0 24px rgba(237, 160, 92, 0.18);
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s;
    z-index: 5;
  }

  .rk-pain-hint {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #6e6259;
  }

  .rk-holes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .rk-hole-card {
    background: #211d19;
    border: 1px solid #35302b;
    border-radius: 14px;
    padding: 24px;
  }
  .rk-hole-title {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #eda05c;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .rk-hole-desc {
    font-size: 15px;
    line-height: 1.6;
    color: #cfc5b8;
    margin: 0 0 16px;
  }
  .rk-hole-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #7e7166;
    border-top: 1px solid #35302b;
    padding-top: 12px;
  }

  .rk-pain-closing {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.55;
    margin: 30px 0 0;
    max-width: 820px;
  }
  .rk-pain-closing-hl {
    color: #eda05c;
    font-weight: 500;
  }

  /* rk-fixes (index.html:47–50), @media 620px — [data-report] сохранён как
     реальный JS-хук (см. комментарий выше), селектор продолжает матчиться. */
  @media (max-width: 620px) {
    [data-report] {
      max-width: 100% !important;
    }
    [data-report] > div {
      padding-left: 12px !important;
      padding-right: 12px !important;
    }
  }

  /* rk-fixes (index.html:186–190), @media 768px — допорчено поверх уже
     существующего в global.css .rk-holes{grid-template-columns:1fr!important}
     (index.html:258–306) для того же брейкпоинта; см. комментарий в шапке файла. */
  @media (max-width: 768px) {
    .rk-holes {
      display: flex !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 12px !important;
      margin: 0 -20px;
      padding: 0 20px 10px;
      scrollbar-width: none;
    }
    .rk-holes::-webkit-scrollbar {
      display: none;
    }
    .rk-holes > div {
      flex: 0 0 80%;
      scroll-snap-align: center;
      min-width: 0;
    }
  }
</style>
