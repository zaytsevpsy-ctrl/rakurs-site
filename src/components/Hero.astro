---
// Портировано из index.html:353–503 (section#top: headline/subline/CTA + SVG
// "MONEY-LEAK PIPE (auto-play)"). Весь диапазон учтён 1:1, кроме:
//  - <defs> groups #coin/#note/#scoin/#crack (index.html:391–394) не используются
//    нигде в этой SVG никаким <use> — мёртвая разметка уже в легаси. Оставлены
//    как есть (byte-for-byte) ради честного 1:1-порта, эффекта на рендер не дают.
//  - <style> из <defs> (index.html:372–390: @keyframes rk*/ .rk* классы) — по
//    правилу порта перенесён из <defs><style> в скоуп-стили компонента ниже
//    (тот же CSS, просто не внутри инлайн-SVG). Astro сам добавит скоуп-атрибут
//    и к <g class="rkFlow">-элементам, и к правилам .rkFlow{...} — работает как раньше.
//
// ВАЖНО про Task 16 / "scrub" из брифа этой задачи:
//  Ни `{{ scrub }}`, ни ручка-регулятор в этом диапазоне (353–503) НЕ существуют.
//  state.scrub = 0.28 и data-scrub-panel/data-scrub-handle/data-scrub-hint — это
//  ВИТРИНА/дашборд-симулятор (index.html:835–852, Task 10 Storefront), не Hero.
//  Труба в Hero — чистая автономная CSS/SVG-анимация (классы rkFlow/rkFeedL/
//  rkFeedR/rkLkL/rkLkR/rkTrk/rkRing/rkBob/rkToss/rkLens/rkCrk, @keyframes ниже),
//  без единого JS-хука.
//  Более того: support.js.setupPipe() (index.html:1459) ищет
//  [data-pipe-scene]/[data-pipe-ring]/[data-crack]/[data-card]/[data-found]/
//  [data-pipe-hint] — ни один из этих атрибутов НЕ встречается нигде в текущем
//  index.html (grep подтверждает 0 совпадений разметки); функция сразу делает
//  `if (!scene) return`. Это мёртвый код, оставшийся от более ранней
//  hover-интерактивной версии трубы. Аналогично `ref="{{ pipe }}"` и
//  `ref="{{ flowLine }}"` (см. renderVals() в support.js) нигде не проставлены
//  в разметке — тоже осиротевшие рефы.
//  ⇒ Для Task 16 (или любой другой задачи, которая захочет оживить трубу) здесь
//  НЕ добавлены фиктивные data-pipe-scrub/data-pipe-value — добавлять их без
//  реального потребителя было бы обманом контракта. Если понадобится
//  интерактивность трубы — это отдельная фича сверх 1:1-порта, не автопорт.
//
// Единственный реально используемый в этом диапазоне JS-хук легаси —
// `ref="{{ magnet }}"` на первичной CTA (index.html:360, setupMagnet() в
// support.js двигает кнопку за курсором). Заменён на стабильный атрибут
// `data-magnet` — будущий скрипт должен делать
// `root.querySelector('[data-magnet]')` вместо старого ref-колбэка.
//
// Классы/id, за которые цепляются @media в src/styles/global.css — НЕ переименовывать:
//  - `#top`, `#top > div` (= .rk-hero-grid), `#top > div > div` (два прямых
//    потомка: текстовая колонка и .rk-hero-pipe) — @media 900px/620px.
//  - `.rk-pipe` — @media 560px/380px (zoom). Добавлен вторым классом на тот же
//    div, что и легаси `.rk-hero-pipe` (в исходнике это два РАЗНЫХ правила из
//    двух разных легаси <style>-блоков, которые относятся к одному и тому же
//    элементу — см. index.html:170 `.rk-hero-pipe>div{max-width:330px!important}`
//    и index.html:301/304 `.rk-pipe{zoom:...}`; оба порчены сюда).
//  - `.rk-hero-pipe > div { max-width: 330px !important }` при ≤900px
//    (index.html:170) ещё нигде не портировано (Nav.astro явно ограничился
//    только nav-правилами из того же легаси-блока) — добавлено в scoped-стиль
//    ниже.
import { t } from '../i18n/ui';
import type { Locale } from '../lib/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale).hero;
