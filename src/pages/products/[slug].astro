---
// Task 19 — RU-версия детальной страницы продукта: /products/<slug>/.
// Заголовок/тело собраны из content collection `products` (см. ProductDetail.astro
// для разметки заголовка и src/content/products/<slug>.ru.md для тела статьи).
// Service JSON-LD 1:1 по структуре с itemOffered из professionalService()
// (src/lib/jsonld.ts) — здесь как отдельный самостоятельный Service под ID
// страницы, provider ссылается на общий #org (см. Base title="og:site_name" etc).
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import LeadForm from '../../components/LeadForm.astro';
import ProductDetail from '../../components/ProductDetail.astro';
import { getLocalized } from '../../lib/content';
import { productService } from '../../lib/jsonld';

export async function getStaticPaths() {
  const products = await getLocalized('products', 'ru');
  return products.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const locale = 'ru' as const;
const backHref = `${import.meta.env.BASE_URL}#storefront`;
---
<Base
  title={`${d.code} — ${d.title} | Rakurs`}
  description={d.desc}
  path={`products/${entry.slug}`}
  locale={locale}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(productService(Astro.site!.href, d))} />
  </Fragment>
  <Nav locale={locale} path={`products/${entry.slug}`} />
  <main>
    <ProductDetail product={entry} locale={locale} backHref={backHref}>
      <Content />
    </ProductDetail>
    <LeadForm locale={locale} />
  </main>
  <Footer locale={locale} />
</Base>
